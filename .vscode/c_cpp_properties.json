{
    "version": 4,
    "configurations": [
        {
            "name": "Linux",
            "compilerPath": "/usr/bin/gcc",
            "intelliSenseMode": "linux-gcc-x64",
            "cStandard": "gnu17",
            "cppStandard": "c++17",
            "defines": [
                "_DEFAULT_SOURCE",
                "_POSIX_C_SOURCE=200809L"
            ],
            "includePath": [
                "${workspaceFolder}",
                "${workspaceFolder}/echo",
                "${workspaceFolder}/webproxy-lab",
                "${workspaceFolder}/webproxy-lab/.proxy",
                "${workspaceFolder}/webproxy-lab/tiny",
                "${workspaceFolder}/**"
            ],
            "browse": {
                "path": [
                    "${workspaceFolder}",
                    "${workspaceFolder}/echo",
                    "${workspaceFolder}/webproxy-lab",
                    "${workspaceFolder}/webproxy-lab/.proxy",
                    "${workspaceFolder}/webproxy-lab/tiny"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        }
    ]
}
